NODE_ENV=development
PORT=5000

# Database
MONGO_URI=mongodb://127.0.0.1:27017/organic_agent

# Auth
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Frontend origin
# Development uses FRONTEND_URL; production prefers VERCEL_FRONTEND_URL.
FRONTEND_URL=http://localhost:5173
VERCEL_FRONTEND_URL=https://organicstore.vercel.app

# Payments
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
